{{!
    @template mod_videotrack/player

    VideoTrack player template.

    Context variables required for this template:
    * isyoutube - Whether the video is from YouTube.
    * ytid - The YouTube video ID.
    * videourl - The URL of the video file (if not YouTube).
    * progresstitle - The title for the progress section.
    * currentpercent - The current progress percentage.
    * progresshint - A hint text about the required progress.
    * iscompleted - Whether the user has reached the required percentage.
    * successmsg - The success message to show upon completion.

    Example context (json):
    {
        "isyoutube": false,
        "ytid": "",
        "videourl": "https://example.com/video.mp4",
        "progresstitle": "Progress",
        "currentpercent": 50,
        "progresshint": "Watch 80% to complete",
        "iscompleted": false,
        "successmsg": "Congratulations!"
    }
}}
<div class="videotrack-container p-3 mb-4 bg-white rounded border shadow-sm">
    
    <!-- Botón de reanudar (Arriba) -->
    {{#showresumebutton}}
    <div class="mb-3">
        <button id="vt-resume-btn" class="btn btn-primary font-weight-bold shadow-sm" style="border-radius: 20px; padding: 8px 20px;">
            <i class="fa fa-play mr-2"></i> {{ resumebtntext }}
        </button>
    </div>
    {{/showresumebutton}}

    {{#isyoutube}}
        <!-- Reproductor de YouTube -->
        <div class="embed-responsive embed-responsive-16by9" style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 8px;">
            <div id="youtube-player" data-videoid="{{ytid}}" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"></div>
        </div>
    {{/isyoutube}}
    
    {{^isyoutube}}
        <!-- Reproductor nativo HTML5 (Archivos locales / MP4 directo) -->
        <div style="border-radius: 8px; overflow: hidden; background: #000; text-align: center;">
            <video id="videotrack-player" controls style="width: 100%; max-height: 650px;">
                <source src="{{videourl}}" type="video/mp4">
                Tu navegador no soporta video HTML5.
            </video>
        </div>
    {{/isyoutube}}

    <!-- Interfaz de Progreso -->
    <div class="mt-4 px-2">
        <h4 class="h5 font-weight-bold">{{ progresstitle }}</h4>
        <div class="progress mt-2" style="height: 25px; border-radius: 12px; background-color: #e9ecef;">
            <div id="vt-progress-bar" class="progress-bar progress-bar-striped progress-bar-animated bg-info" role="progressbar" style="width: {{currentpercent}}%; min-width: 35px; transition: width 0.5s;" aria-valuenow="{{currentpercent}}" aria-valuemin="0" aria-valuemax="100">
                <span id="vt-progress-text" class="font-weight-bold" style="font-size: 14px;">{{currentpercent}}%</span>
            </div>
        </div>
        <p class="mt-2 text-muted small">{{{ progresshint }}}</p>
        
        <!-- Mensaje de éxito -->
        <div id="vt-success-msg" class="alert alert-success mt-3 {{^iscompleted}}d-none{{/iscompleted}}" style="border-left: 5px solid #28a745;">
            <i class="fa fa-check-circle mr-1"></i> {{ successmsg }}
        </div>
    </div>
</div>

{{#js}}
require(['jquery'], function($) {
    $('#vt-resume-btn').on('click', function(e) {
        e.preventDefault();
        var btn = $(this);
        var targetPercent = {{currentpercent}};
        
        var isYouTube = {{#isyoutube}}true{{/isyoutube}}{{^isyoutube}}false{{/isyoutube}};

        if (!isYouTube) {
            var video = document.getElementById('videotrack-player');
            if (!video) return;

            var doResume = function() {
                var targetTime = (targetPercent / 100) * video.duration;
                video.currentTime = targetTime;
                video.play();
                btn.fadeOut();
            };

            if (video.readyState >= 1) {
                doResume();
            } else {
                video.addEventListener('loadedmetadata', doResume, {once: true});
                video.load();
            }
        } else {
            if (window.ytPlayer && window.ytPlayer.playVideo) {
                window.ytPlayer.playVideo();
                var checkInterval = setInterval(function() {
                    var dur = window.ytPlayer.getDuration();
                    if (dur && dur > 0) {
                        clearInterval(checkInterval);
                        window.ytPlayer.seekTo((targetPercent / 100) * dur, true);
                        btn.fadeOut();
                    }
                }, 200);
            }
        }
    });

    // Ocultar botón si el video se reproduce manualmente
    var isYouTube = {{#isyoutube}}true{{/isyoutube}}{{^isyoutube}}false{{/isyoutube}};
    if (!isYouTube) {
        var video = document.getElementById('videotrack-player');
        if (video) {
            video.addEventListener('play', function() {
                $('#vt-resume-btn').fadeOut();
            });
        }
    } else {
        // En youtube dependemos del event listener global, pero podemos añadir un polling si queremos,
        // aunque ytPlayer.playVideo lo ocultará indirectamente, así que no es estrictamente necesario aquí.
    }
});
{{/js}}